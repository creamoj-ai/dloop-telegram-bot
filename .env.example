# ============================================================================
# DLOOP TELEGRAM BOT - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values

# ─────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT
# ─────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=@dloop_Order_bot
TELEGRAM_WEBHOOK_URL=https://dloop-bot.render.com/webhook
WEBHOOK_PORT=3000

# SHOSHY's Telegram user ID (for admin commands)
# Get this by running the bot and sending /start, then checking logs
SHOSHY_TELEGRAM_USER_ID=YOUR_USER_ID_HERE

# ─────────────────────────────────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://aqpwfurradxbnqvycvkm.supabase.co
SUPABASE_ANON_KEY=sb_publishable_NBWU-byCV0TIsj5-8Mixog_CEV7IkrB
SUPABASE_PROJECT_ID=aqpwfurradxbnqvycvkm

# ─────────────────────────────────────────────────────────────────────────
# STRIPE (TEST MODE)
# ─────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE_... (set this after creating webhook in Stripe)

# ─────────────────────────────────────────────────────────────────────────
# FIREBASE (FCM PUSH NOTIFICATIONS)
# ─────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=dloopriderapp
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# ─────────────────────────────────────────────────────────────────────────
# RUNTIME
# ─────────────────────────────────────────────────────────────────────────
NODE_ENV=development
DEBUG=false
